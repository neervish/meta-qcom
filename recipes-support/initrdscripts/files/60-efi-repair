#!/bin/sh
# Purpose:
#   Verify health of the *normal* EFI System Partition (efi.bin).
#   This script does NOT perform recovery itself.
#
# Output:
#   Writes EFI_STATUS to /run/recovery.efi

set -eu

RECOVERY_MODE="$(cat /run/recovery.mode 2>/dev/null || echo 0)"
[ "$RECOVERY_MODE" = "1" ] || exit 0

echo "[recovery] EFI check: start"

EFI_STATUS="unknown"
ESP_DEV=""

# Locate normal ESP (vfat)
for cand in $(blkid -t TYPE=vfat -o device 2>/dev/null); do
    ESP_DEV="$cand"
    break
done

if [ -z "$ESP_DEV" ]; then
    echo "[recovery] EFI check: no ESP found"
    EFI_STATUS="broken"
else
    mkdir -p /mnt/esp

    if mount -t vfat -o ro "$ESP_DEV" /mnt/esp; then
        EFI_STATUS="healthy"

        # Layer 1: firmware entry point
        if [ ! -f /mnt/esp/EFI/BOOT/bootaa64.efi ]; then
            echo "[recovery] EFI check: missing EFI/BOOT/bootaa64.efi"
            EFI_STATUS="broken"
        fi

        # Layer 2: normal UKI
        if [ ! -f /mnt/esp/EFI/Linux/linux-${MACHINE}.efi ]; then
            echo "[recovery] EFI check: missing normal UKI"
            EFI_STATUS="broken"
        fi

        umount /mnt/esp || true
    else
        echo "[recovery] EFI check: failed to mount ESP"
        EFI_STATUS="broken"
    fi
fi

# Publish result for downstream scripts
echo "EFI_STATUS=${EFI_STATUS}" > /run/recovery.efi

echo "[recovery] EFI check: ${EFI_STATUS}"
exit 0
