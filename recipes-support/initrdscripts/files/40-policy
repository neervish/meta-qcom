#!/bin/sh
# Purpose: detect recovery mode and publish effective policy.
# initramfs-framework module name: "policy"

policy_enabled() {
    return 0
}

policy_run() {
    POLICY=/etc/recovery/policy.conf
    STATE_DIR=/run
    RECOVERY_FLAG="${STATE_DIR}/recovery.mode"
    POLICY_SNAPSHOT="${STATE_DIR}/recovery.policy"

    MODE_DEFAULT="recovery"
    ALLOW_SHELL_DEFAULT="1"
    MODE="${MODE_DEFAULT}"
    ALLOW_SHELL="${ALLOW_SHELL_DEFAULT}"
    RECOVERY_MODE=0

    mkdir -p "${STATE_DIR}"

    # Optional policy file for integrator customization.
    [ -f "${POLICY}" ] && . "${POLICY}" 2>/dev/null || true
    MODE="${MODE:-${MODE_DEFAULT}}"
    ALLOW_SHELL="${ALLOW_SHELL:-${ALLOW_SHELL_DEFAULT}}"

    if grep -qw 'recovery_mode=1' /proc/cmdline 2>/dev/null; then
        RECOVERY_MODE=1
    fi

    if [ "${RECOVERY_MODE}" = "0" ] &&
       ls /sys/firmware/efi/efivars/LoaderImageIdentifier-* >/dev/null 2>&1; then
        RECOVERY_MODE=1
    fi

    if [ "${MODE}" = "always" ]; then
        RECOVERY_MODE=1
    fi

    echo "${RECOVERY_MODE}" > "${RECOVERY_FLAG}"

    {
        echo "MODE=${MODE}"
        echo "ALLOW_SHELL=${ALLOW_SHELL}"
        echo "RECOVERY_MODE=${RECOVERY_MODE}"
    } > "${POLICY_SNAPSHOT}"

    return 0
}
