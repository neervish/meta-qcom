#!/bin/sh

CONF="/etc/initramfs/ethernet.conf"

log_msg() {
    if command -v msg >/dev/null 2>&1; then
        msg "$@"
    else
        echo "$@"
    fi
}

ethernet_enabled() {
    [ -r "${CONF}" ]
}

ethernet_run() {
    ETH_MODULES=""
    ETH_FW_PARTLABEL=""
    ETH_FW_FILES=""
    ETH_FW_FSTYPE="ext4"

    # Runtime configuration is generated by the recipe from BitBake variables.
    # Keeping this script config-driven makes it reusable outside Yocto layers.
    . "${CONF}" 2>/dev/null || true
    [ -n "${ETH_FW_FSTYPE}" ] || ETH_FW_FSTYPE="ext4"

    log_msg "[eth] Initramfs Ethernet bring-up started"

    #
    # 1. Firmware handling (only if configured)
    #
    if [ -n "${ETH_FW_PARTLABEL}" ]; then
        FW_DEV="/dev/disk/by-partlabel/${ETH_FW_PARTLABEL}"

        if [ ! -e "$FW_DEV" ]; then
            log_msg "[eth] Firmware partition not found: ${ETH_FW_PARTLABEL}"
        else
            log_msg "[eth] Firmware partition found, attempting mount"

            mkdir -p /mnt/eth_fw

            if mount -t "${ETH_FW_FSTYPE}" "$FW_DEV" /mnt/eth_fw 2>/dev/null; then
                log_msg "[eth] Firmware partition mounted successfully"

                # Create firmware dir ONLY after successful mount
                mkdir -p /lib/firmware

                for fw in ${ETH_FW_FILES}; do
                    if [ -f "/mnt/eth_fw/$fw" ]; then
                        cp "/mnt/eth_fw/$fw" /lib/firmware/
                        log_msg "[eth] Copied firmware: $fw"
                    else
                        log_msg "[eth] Firmware file missing: $fw"
                    fi
                done

                umount /mnt/eth_fw 2>/dev/null || \
                    log_msg "[eth] Warning: failed to unmount firmware partition"
            else
                log_msg "[eth] Failed to mount firmware partition"
            fi
        fi
    fi

    #
    # 2. Load kernel modules
    #
    for pkg in ${ETH_MODULES}; do
        mod="$(echo "${pkg#kernel-module-}" | tr '-' '_')"
        if command -v load_kernel_module >/dev/null 2>&1; then
            load_kernel_module "$mod"
        elif command -v modprobe >/dev/null 2>&1; then
            modprobe "$mod" 2>/dev/null || true
        fi
    done


    #
    # 3. Optional xHCI bind with timeout (machine-specific)
    #
#    if [ -n "${ETH_NEEDS_XHCI_BIND}" ] && \
#       [ -n "${ETH_XHCI_DRIVER}" ]; then
#
#        log_msg "[eth] Attempting xHCI bind"
#        bind_timeout=5
#
#        while [ $bind_timeout -gt 0 ]; do
#            bound=0
#            for dev in /sys/bus/pci/devices/*; do
#                if [ -e "$dev/class" ] && grep -q 0x0c03 "$dev/class"; then
#                    if echo "$(basename "$dev")" > \
#                        "/sys/bus/pci/drivers/${ETH_XHCI_DRIVER}/bind" \
#                        2>/dev/null; then
#                        log_msg "[eth] Bound xHCI device $(basename "$dev")"
#                        bound=1
#                    fi
#                fi
#            done
#
#            [ $bound -eq 1 ] && break
#            sleep 1
#            bind_timeout=$((bind_timeout - 1))
#        done
#
#        [ $bind_timeout -eq 0 ] && \
#           log_msg "[eth] xHCI bind timeout reached"
#    fi

    #
    # 4. Discover Ethernet interfaces with timeout
    #
    timeout=5
    while [ $timeout -gt 0 ]; do
        found=""
        for iface in /sys/class/net/*; do
            name="$(basename "$iface")"
            [ "$name" = "lo" ] && continue
            [ -e "$iface/device" ] && found="$found $name"
        done
        [ -n "$found" ] && break
        sleep 1
        timeout=$((timeout - 1))
    done

    #
    # 5. Bring up all detected interfaces and request DHCP
    #
    if [ -n "$found" ]; then
        for name in $found; do
            log_msg "[eth] Bringing up $name"
            ip link set "$name" up 2>/dev/null || continue
            udhcpc -i "$name" -t 5 && \
                log_msg "[eth] DHCP success on $name"
        done
    else
        log_msg "[eth] No Ethernet interfaces detected"
    fi

    log_msg "[eth] Ethernet initramfs step complete"
}
